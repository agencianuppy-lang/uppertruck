<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1) Forçar HTTPS (uppertruck.com e www.uppertruck.com)
    RewriteCond %{HTTP_HOST} ^(www\.)?uppertruck\.com$ [NC]
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # 2) Bloquear métodos perigosos
    RewriteCond %{REQUEST_METHOD} ^TRACE [NC]
    RewriteRule ^ - [F]

    # 3) Proteger arquivos sensíveis (Apache 2.4+ e 2.2)
    <FilesMatch "^(\.env|\.git|composer\.json|composer\.lock|package\.json|README\.md)$">
        <IfModule mod_authz_core.c>
            Require all denied
        </IfModule>
        <IfModule !mod_authz_core.c>
            Order allow,deny
            Deny from all
        </IfModule>
    </FilesMatch>

    # 4) Remover barra final (exceto diretórios reais)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [R=301,L]

    # 5) Rotas do BLOG (suas páginas PHP)
    RewriteRule ^blog-br/?$ new-blog.php [L,QSA]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^blog/([^/]+)$ detalhe-newblog.php?slug=$1 [L,QSA]

    # 6) Rota do SISTEMA
    RewriteRule ^sistema/?$ sistema/index.php [L,QSA]

    # 7) HOME: / e /index.php -> novosite/index.php
    RewriteRule ^$ novosite/index.php [L]
    RewriteRule ^index\.php$ novosite/index.php [L]

    # 7.9) URL amigável específica (ANTES do fallback)
    RewriteRule ^transportadora-para-industria/?$ transportadora-para-industria.php [L,QSA]

    # 8) Fallback: qualquer outra rota "amigável" cai no novosite/index.php
    # (sem mexer em /blog, /sistema e /novosite)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/(blog|sistema|novosite)(/|$) [NC]
    RewriteRule . novosite/index.php [L]

</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Defina o pacote “ea-php81” como a linguagem padrão de programação “PHP”.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
